@page "/invernaderos"
@attribute [Authorize(Roles = "Admin")]
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@using BlazorClient.Models
@using BlazorClient.Services
@inject IApiClient ApiClient

<PageTitle>Gestión de Invernaderos</PageTitle>

<div class="container mt-4">
    <h2>🏗️ Gestión de Invernaderos</h2>
    <p class="lead">Página exclusiva para <strong>Administradores</strong>.</p>

    <div class="alert alert-info">
        Desde aquí los administradores dan de alta nuevos invernaderos en el sistema.
        Una vez creados, se pueden asignar sensores y configurar umbrales de alarmas.
    </div>

    <!-- Botón crear -->
    <div class="mb-3">
        <button class="btn btn-success" @onclick="MostrarFormularioCrear" disabled="@cargando">
            ➕ Nuevo invernadero
        </button>
        <button class="btn btn-outline-secondary ms-2" @onclick="CargarInvernaderos" disabled="@cargando">
            @if (cargando)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
                <span>Cargando...</span>
            }
            else
            {
                <span>🔄 Refrescar</span>
            }
        </button>
    </div>

    <!-- Mensajes de feedback -->
    @if (mensajeExito != null)
    {
        <div class="alert alert-success alert-dismissible">
            ✅ @mensajeExito
            <button type="button" class="btn-close" @onclick="() => mensajeExito = null"></button>
        </div>
    }
    @if (mensajeError != null)
    {
        <div class="alert alert-danger alert-dismissible">
            ❌ @mensajeError
            <button type="button" class="btn-close" @onclick="() => mensajeError = null"></button>
        </div>
    }

    <!-- Formulario de creación -->
    @if (mostrarFormulario)
    {
        <div class="card border-success mb-3">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Nuevo invernadero</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">ID del invernadero <span class="text-danger">*</span></label>
                        <input type="text" class="form-control"
                               placeholder="Ej: INV-002"
                               @bind="nuevoInvernadero.Id" @bind:event="oninput"
                               disabled="@guardando" />
                        <div class="form-text">Identificador único, mayúsculas y guiones.</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input type="text" class="form-control"
                               placeholder="Ej: Invernadero Sur"
                               @bind="nuevoInvernadero.Nombre" @bind:event="oninput"
                               disabled="@guardando" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Ubicación <span class="text-danger">*</span></label>
                        <input type="text" class="form-control"
                               placeholder="Ej: Hermosillo, Sonora"
                               @bind="nuevoInvernadero.Ubicacion" @bind:event="oninput"
                               disabled="@guardando" />
                    </div>
                </div>

                @if (ValidacionFormulario != null)
                {
                    <div class="alert alert-warning mt-3 mb-0">
                        ⚠️ @ValidacionFormulario
                    </div>
                }

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-success"
                            @onclick="GuardarInvernadero"
                            disabled="@(guardando || ValidacionFormulario != null)">
                        @if (guardando)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <span>💾 Guardar</span>
                        }
                    </button>
                    <button class="btn btn-outline-secondary"
                            @onclick="CancelarFormulario"
                            disabled="@guardando">
                        Cancelar
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Tabla de invernaderos -->
    <div class="card">
        <div class="card-body">
            <h5>Invernaderos registrados</h5>

            @if (error != null)
            {
                <div class="alert alert-danger">
                    <strong>Error al cargar:</strong> @error
                </div>
            }
            else if (cargando && invernaderos.Count == 0)
            {
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Cargando invernaderos...</p>
                </div>
            }
            else if (invernaderos.Count == 0)
            {
                <div class="alert alert-warning mb-0">No hay invernaderos registrados.</div>
            }
            else
            {
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Ubicación</th>
                            <th>Registrado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in invernaderos.OrderBy(i => i.Id))
                        {
                            <tr>
                                <td><strong>@inv.Id</strong></td>
                                <td>@inv.Nombre</td>
                                <td>@inv.Ubicacion</td>
                                <td>
                                    <small class="text-muted">
                                        @inv.FechaRegistro.ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger"
                                            disabled
                                            title="DELETE no implementado en el Gateway — trabajo futuro">
                                        🗑️ Eliminar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <p class="text-muted small mb-0">
                    Total: <strong>@invernaderos.Count</strong> invernaderos
                </p>
            }
        </div>
    </div>
</div>

@code {
    private List<InvernaderoDto> invernaderos = new();
    private bool cargando = false;
    private bool guardando = false;
    private bool mostrarFormulario = false;
    private string? error = null;
    private string? mensajeExito = null;
    private string? mensajeError = null;

    private InvernaderoDto nuevoInvernadero = new();

    private string? ValidacionFormulario
    {
        get
        {
            if (string.IsNullOrWhiteSpace(nuevoInvernadero.Id))
                return "El ID es obligatorio.";
            if (string.IsNullOrWhiteSpace(nuevoInvernadero.Nombre))
                return "El nombre es obligatorio.";
            if (string.IsNullOrWhiteSpace(nuevoInvernadero.Ubicacion))
                return "La ubicación es obligatoria.";
            if (invernaderos.Any(i => i.Id.Equals(nuevoInvernadero.Id, StringComparison.OrdinalIgnoreCase)))
                return $"Ya existe un invernadero con ID '{nuevoInvernadero.Id}'.";
            return null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarInvernaderos();
    }

    private async Task CargarInvernaderos()
    {
        cargando = true;
        error = null;
        StateHasChanged();

        try
        {
            invernaderos = await ApiClient.GetInvernaderosAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            invernaderos = new();
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private void MostrarFormularioCrear()
    {
        nuevoInvernadero = new InvernaderoDto();
        mostrarFormulario = true;
        mensajeExito = null;
        mensajeError = null;
    }

    private void CancelarFormulario()
    {
        mostrarFormulario = false;
        nuevoInvernadero = new InvernaderoDto();
    }

    private async Task GuardarInvernadero()
    {
        if (ValidacionFormulario != null) return;

        guardando = true;
        mensajeError = null;
        StateHasChanged();

        try
        {
            var ok = await ApiClient.PostInvernaderoAsync(nuevoInvernadero);
            if (ok)
            {
                mensajeExito = $"Invernadero '{nuevoInvernadero.Nombre}' creado correctamente.";
                mostrarFormulario = false;
                nuevoInvernadero = new InvernaderoDto();
                await CargarInvernaderos();
            }
            else
            {
                mensajeError = "El servidor rechazó la creación. Verifica permisos o que el ID no esté duplicado.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error de red: {ex.Message}";
        }
        finally
        {
            guardando = false;
            StateHasChanged();
        }
    }
}
