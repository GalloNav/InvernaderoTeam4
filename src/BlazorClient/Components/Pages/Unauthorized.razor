@page "/unauthorized"

<PageTitle>Acceso denegado</PageTitle>

<div class="container mt-5">
    <div class="card border-danger">
        <div class="card-body text-center">
            <h2 class="text-danger">🚫 Acceso denegado</h2>
            <p class="lead">
                No tienes los permisos necesarios para acceder a esta sección.
            </p>
            <p class="text-muted">
                Tu rol actual no permite esta operación. Si crees que es un error,
                contacta a un administrador del sistema.
            </p>
            <a href="/" class="btn btn-primary">Volver al Dashboard</a>
        </div>
    </div>
</div>
