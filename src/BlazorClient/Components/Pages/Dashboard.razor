@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@implements IDisposable
@implements IAsyncDisposable
@inject IApiClient ApiClient
@inject TokenCache TokenCache
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Dashboard — Invernadero IoT</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Dashboard en tiempo real</h4>
    <span class="badge @(_hubConectado ? "bg-success" : "bg-secondary")">
        @(_hubConectado ? "Conectado" : "Desconectado")
    </span>
</div>

<div class="row g-3">
    <!-- Mediciones -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-success text-white">
                Ultimas mediciones (@_mediciones.Count)
            </div>
            <div class="card-body p-0" style="max-height:480px;overflow-y:auto;">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>Sensor</th>
                            <th>Inv.</th>
                            <th>Temp (°C)</th>
                            <th>Hum (%)</th>
                            <th>Hora</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _mediciones)
                        {
                            <tr>
                                <td>@m.SensorId</td>
                                <td>@m.InvernaderoId</td>
                                <td>@m.Temperatura.ToString("F1")</td>
                                <td>@m.Humedad.ToString("F1")</td>
                                <td>@m.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Alarmas -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-danger text-white">
                Alarmas activas (@_alarmas.Count)
            </div>
            <div class="card-body p-0" style="max-height:480px;overflow-y:auto;">
                @if (_alarmas.Count == 0)
                {
                    <div class="p-3 text-muted">Sin alarmas recientes.</div>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Sensor</th>
                                <th>Tipo</th>
                                <th>Valor</th>
                                <th>Umbral</th>
                                <th>Hora</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _alarmas)
                            {
                                <tr class="table-warning">
                                    <td>@a.SensorId</td>
                                    <td>@a.Tipo</td>
                                    <td>@a.ValorMedido.ToString("F1")</td>
                                    <td>@a.UmbralConfigurado.ToString("F1")</td>
                                    <td>@a.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<MedicionDto> _mediciones = [];
    private List<AlarmaDto>   _alarmas    = [];
    private HubConnection? _hub;
    private bool _hubConectado;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += HandleLocationChanged;
        await CargarDatosInicialesAsync();
        await ConectarSignalRAsync();
    }

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // La ruta del dashboard es "/", comprobamos el path absoluto
        var path = new Uri(e.Location).AbsolutePath;
        if (path == "/")
        {
            Console.WriteLine($"[Dashboard] LocationChanged detectado: {e.Location}");
            try
            {
                await CargarDatosInicialesAsync();
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Dashboard] Error en LocationChanged: {ex.Message}");
            }
        }
    }

    private async Task CargarDatosInicialesAsync()
    {
        Console.WriteLine("[Dashboard] CargarDatosInicialesAsync ejecutándose");
        try
        {
            var meds = await ApiClient.GetMedicionesAsync();
            _mediciones = meds.Take(20).ToList();
            Console.WriteLine($"[Dashboard] Cargadas {_mediciones.Count} mediciones");
            // Las alarmas son eventos en tiempo real vía SignalR — no se cargan via REST

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Dashboard] Error cargando datos: {ex.Message}");
            Console.WriteLine($"[Dashboard] StackTrace: {ex.StackTrace}");
        }
    }

    private async Task ConectarSignalRAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var sub = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                  ?? authState.User.FindFirst("sub")?.Value;
        var token = !string.IsNullOrEmpty(sub) ? TokenCache.Get(sub) : null;

        var hubUrl = string.IsNullOrEmpty(token)
            ? "http://localhost:5000/hubs/eventos"
            : $"http://localhost:5000/hubs/eventos?access_token={token}";

        _hub = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .AddJsonProtocol(opts =>
                opts.PayloadSerializerOptions.PropertyNameCaseInsensitive = true)
            .Build();

        _hub.Reconnected  += _ => { _hubConectado = true;  return InvokeAsync(StateHasChanged); };
        _hub.Reconnecting += _ => { _hubConectado = false; return InvokeAsync(StateHasChanged); };
        _hub.Closed       += _ => { _hubConectado = false; return InvokeAsync(StateHasChanged); };

        _hub.On<MedicionDto>("NuevaMedicion", m =>
        {
            _mediciones.Insert(0, m);
            if (_mediciones.Count > 20) _mediciones.RemoveAt(20);
            InvokeAsync(StateHasChanged);
        });

        _hub.On<AlarmaDto>("NuevaAlarma", a =>
        {
            _alarmas.Insert(0, a);
            if (_alarmas.Count > 20) _alarmas.RemoveAt(20);
            InvokeAsync(StateHasChanged);
        });

        await _hub.StartAsync();
        _hubConectado = true;
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();
        if (_hub is not null)
            await _hub.DisposeAsync();
    }
}
