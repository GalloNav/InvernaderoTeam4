{
  "realm": "invernadero",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 3600,
  "roles": {
    "realm": [
      {
        "name": "Admin",
        "description": "Administrador del sistema con acceso completo"
      },
      {
        "name": "Operador",
        "description": "Operador con acceso a operaciones diarias"
      },
      {
        "name": "Tecnico",
        "description": "Tecnico con acceso a sensores y mantenimiento"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Administrador",
      "lastName": "Sistema",
      "email": "admin@invernadero.local",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["Admin"]
    },
    {
      "username": "operador",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Operador",
      "lastName": "Demo",
      "email": "operador@invernadero.local",
      "credentials": [
        {
          "type": "password",
          "value": "operador123",
          "temporary": false
        }
      ],
      "realmRoles": ["Operador"]
    },
    {
      "username": "tecnico",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Tecnico",
      "lastName": "Demo",
      "email": "tecnico@invernadero.local",
      "credentials": [
        {
          "type": "password",
          "value": "tecnico123",
          "temporary": false
        }
      ],
      "realmRoles": ["Tecnico"]
    }
  ],
  "clients": [
    {
      "clientId": "blazor-client",
      "name": "Blazor Client - Invernadero",
      "description": "Cliente web del sistema de monitoreo de invernaderos",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5006/*",
        "http://localhost:5006/signin-oidc"
      ],
      "webOrigins": [
        "http://localhost:5006",
        "http://localhost:5000"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5006/##http://localhost:5006/signout-callback-oidc"
      },
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ]
}
